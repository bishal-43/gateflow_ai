# ── Backend API (FastAPI microservice) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── RAG / AI microservice (gateflow-ai-main) ──────────────────────────────────
VITE_RAG_BASE_URL=http://localhost:8001

# ── WebSocket (backend real-time) ─────────────────────────────────────────────
VITE_WS_BASE_URL=ws://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_NAME=GateFlow AI

# ── Mock mode — set true when backend is not running (local dev / CI preview) ─
# When false (production/staging), all API calls go to real backend services.
VITE_MOCK_MODE=false
